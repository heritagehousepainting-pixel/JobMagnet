# Copy to .env and fill in. Real env vars always win over .env values.
# JobMagnet runs with ZERO setup in demo mode; add a key to get real AI content.

# AI brain: "demo" (no key, scripted), "claude", or "minimax".
JOBMAGNET_PROVIDER=demo

# Claude (recommended for real content). Set provider=claude too.
# ANTHROPIC_API_KEY=sk-ant-...
# CLAUDE_MODEL=claude-opus-4-8

# MiniMax (OpenAI-compatible). Set provider=minimax too.
# MINIMAX_API_KEY=...
# MINIMAX_MODEL=MiniMax-M2.5
# MINIMAX_BASE_URL=https://api.minimax.io

# Session signing key (set a long random value in production). Also signs the public
# CAN-SPAM unsubscribe links, so keep it stable once set.
# JOBMAGNET_SECRET=change-me-to-a-long-random-value
# JOBMAGNET_HTTPS=1
# JOBMAGNET_DEBUG=0
# JOBMAGNET_PORT=8900
# JOBMAGNET_DB_PATH=/absolute/path/to/jobmagnet.db

# Encrypts stored connection credentials (Twilio/Google/Meta tokens) AT REST. Leave blank
# in dev (creds stored in the clear, UI warns). MUST be set before connecting real accounts.
# Generate: python -c "import secrets; print(secrets.token_urlsafe(48))"
# JOBMAGNET_SECRETS_KEY=

# Shared secret for cron/tasks and non-Stripe webhooks. Required before deploy.
# JOBMAGNET_WEBHOOK_TOKEN=

# Seed owner login (business 1 = Heritage). Change the password after first login.
# JOBMAGNET_OWNER_EMAIL=heritagehousepainting@gmail.com
# JOBMAGNET_OWNER_PASSWORD=jobmagnet123

# Google Business Profile one-click "Connect with Google" (OAuth). Register ONE OAuth app
# in Google Cloud, enable the Business Profile API, and whitelist the redirect URI below
# (must match GOOGLE_REDIRECT_URI exactly). While blank, the Connect button is a safe
# disabled no-op. See SETUP_NEEDED.md (Phase 2) for the full steps.
# GOOGLE_CLIENT_ID=...apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=...
# GOOGLE_REDIRECT_URI=http://localhost:8900/connections/google/callback

# Twilio SMS. Leave blank to simulate SMS.
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM=+15551234567

# SMTP email. Leave blank to simulate email.
# JOBMAGNET_EMAIL_FROM=
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=

# Publishing and media connectors.
# GBP_ACCESS_TOKEN=
# META_ACCESS_TOKEN=
# JOBMAGNET_IMAGE_KEY=

# Optional FirstBack booked-job feed.
# FIRSTBACK_API_URL=
# FIRSTBACK_API_KEY=

# Stripe billing. All prices are required before billing goes live.
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# STRIPE_PRICE_PRO=
# STRIPE_PRICE_PREMIUM=
# STRIPE_PRICE_SCALE=

# Guardrails and pacing.
# JOBMAGNET_QUIET_START=21
# JOBMAGNET_QUIET_END=8
# JOBMAGNET_POST_MIN_GAP=60
# JOBMAGNET_MAILING_ADDRESS=

# Cold phone channels. Keep off unless legal review is complete.
# JOBMAGNET_COLD_SMS=0
# JOBMAGNET_COLD_VOICE=0
